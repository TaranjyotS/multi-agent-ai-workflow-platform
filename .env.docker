APP_NAME=Multi-Agent AI Workflow Platform
ENVIRONMENT=docker
API_KEY=dev-api-key
ENABLE_API_KEY_AUTH=true

# Docker Compose mode: use Docker service names, not localhost.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/multi_agent_ai
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=enterprise_knowledge
LOG_LEVEL=INFO
DEFAULT_PROVIDER=local
