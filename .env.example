APP_NAME=Multi-Agent AI Workflow Platform
ENVIRONMENT=development
API_KEY=dev-api-key
ENABLE_API_KEY_AUTH=true

# Local Python mode: use localhost because the app runs on your machine.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/multi_agent_ai
# Alternative local PostgreSQL mode when Docker services are running:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/multi_agent_ai

REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=enterprise_knowledge
LOG_LEVEL=INFO
DEFAULT_PROVIDER=local
